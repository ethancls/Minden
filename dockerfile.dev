FROM node:22-alpine AS base

# Installation des dépendances système nécessaires
RUN apk add --no-cache libc6-compat git

# Configuration du répertoire de travail
WORKDIR /app

# Copie des fichiers de configuration du package manager
COPY package.json package-lock.json* ./

# Installation des dépendances
FROM base AS deps
RUN npm ci

# Development
FROM base AS runner
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Création d'un utilisateur non-root
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copie des node_modules depuis deps
COPY --from=deps --chown=nextjs:nodejs /app/node_modules ./node_modules

# Copie du code source
COPY --chown=nextjs:nodejs . .

USER nextjs

# Exposition du port pour Next.js et Drizzle Studio
EXPOSE 3000
EXPOSE 4983

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Scripts disponibles pour le développement et les migrations
# docker exec -it container npm run db:push
# docker exec -it container npm run db:studio

CMD ["npm", "run", "dev"]
