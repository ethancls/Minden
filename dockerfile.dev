FROM node:22-alpine

# Configuration du répertoire de travail
WORKDIR /app

# Installation des dépendances système nécessaires
RUN apk add --no-cache git

# Copie des fichiers de configuration du package manager
COPY package.json package-lock.json* ./

# Installation des dépendances avec npm
RUN npm ci

# Copie du code source
COPY . .

# Exposition du port pour Next.js en développement
EXPOSE 3000

# Configuration des variables d'environnement pour le développement
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Commande par défaut pour le développement avec hot reload
CMD ["npm", "run", "dev"]
